<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="{{ canonical }}" />

  <!-- Open Graph / social preview -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Stanford Muslim Student Union" />
  <meta property="og:url" content="{{ canonical }}" />
  <meta property="og:title" content="{{ ogTitle or title }}" />
  <meta property="og:description" content="{{ ogDescription or description }}" />
  <meta property="og:image" content="https://stanford-msu.netlify.app/assets/photos/page_background.png" />

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ ogTitle or title }}" />
  <meta name="twitter:description" content="{{ ogDescription or description }}" />
  <meta name="twitter:image" content="https://stanford-msu.netlify.app/assets/photos/page_background.png" />

  <link rel="icon" type="image/png" href="assets/logos/msu_logo_without_background.png" />
  <meta name="theme-color" content="#8C1515" />

  <link rel="stylesheet" href="css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  {% include "nav.njk" %}

  {{ content | safe }}

  {% include "footer.njk" %}

  <script src="js/script.js"></script>
{% if extraScripts %}{% for s in extraScripts %}
  <script src="{{ s }}"></script>
{% endfor %}{% endif %}
</body>
</html>
